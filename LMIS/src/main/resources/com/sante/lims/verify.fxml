<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="500.0" spacing="20.0" style="-fx-background-color: #0f172a;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sante.lims.controller.VerifyController">
   <children>
      <VBox maxWidth="350.0" spacing="25.0">
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label styleClass="text-title" text="Verify Email">
                     <font>
                        <Font size="22.0" />
                     </font>
                  </Label>
                  <Label styleClass="text-subtitle" text="Please enter the 6-digit code sent to your registered email address." wrapText="true" />
               </children>
            </VBox>
            
            <VBox spacing="10.0">
               <children>
                  <Label text="Verification Code" />
                  <TextField fx:id="codeField" alignment="CENTER" promptText="123456" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-letter-spacing: 5;">
                     <font>
                        <Font size="18.0" />
                     </font>
                  </TextField>
               </children>
            </VBox>
            
            <Label fx:id="errorLabel" textFill="#ef4444" wrapText="true" visible="false" />
            
            <VBox spacing="15.0">
               <children>
                  <Button fx:id="verifyButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleVerify" text="Verify Account" />
                  <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleResendCode" styleClass="secondary-button" text="Resend Code" />
               </children>
            </VBox>
            
            <VBox alignment="CENTER">
               <children>
                  <Hyperlink onAction="#handleBackToLogin" text="Back to Login" textFill="#2dd4bf" />
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
</VBox>
