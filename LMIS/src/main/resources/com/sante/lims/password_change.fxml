<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="500.0" spacing="20.0" style="-fx-background-color: #0f172a;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sante.lims.controller.PasswordChangeController">
   <children>
      <VBox maxWidth="350.0" spacing="25.0">
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label styleClass="text-title" text="Change Password">
                     <font>
                        <Font size="22.0" />
                     </font>
                  </Label>
                  <Label styleClass="text-subtitle" text="For security reasons, you must change your temporary password on your first login." wrapText="true" />
               </children>
            </VBox>
            
            <VBox spacing="15.0">
               <children>
                  <VBox spacing="5.0">
                     <children>
                        <Label text="New Password" />
                        <PasswordField fx:id="newPasswordField" promptText="At least 6 characters" />
                     </children>
                  </VBox>
                  
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Confirm New Password" />
                        <PasswordField fx:id="confirmPasswordField" promptText="Repeat new password" />
                     </children>
                  </VBox>
               </children>
            </VBox>
            
            <Label fx:id="errorLabel" textFill="#ef4444" wrapText="true" visible="false" />
            
            <Button fx:id="changeButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleChangePassword" text="Update Password" />
            
            <VBox alignment="CENTER">
               <children>
                  <Hyperlink onAction="#handleCancel" text="Cancel and Sign Out" textFill="#2dd4bf" />
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
</VBox>
