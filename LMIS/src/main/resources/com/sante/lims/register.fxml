<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="640.0" prefWidth="900.0" styleClass="root" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sante.lims.controller.RegisterController">
   <children>
      <VBox alignment="CENTER_LEFT" prefHeight="640.0" prefWidth="370.0" spacing="22.0" styleClass="auth-brand-panel" HBox.hgrow="ALWAYS">
         <children>
            <VBox spacing="2.0">
               <children>
                  <Label text="SANTE" textFill="#ccfbf1">
                     <font>
                        <Font name="System Bold" size="40.0" />
                     </font>
                  </Label>
                  <Label text="Diagnostics Ltd" textFill="#ffffff">
                     <font>
                        <Font size="24.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
            <Label text="Digital Laboratory Portal" textFill="#d9f8f2" wrapText="true">
               <font>
                  <Font size="15.0" />
               </font>
            </Label>
            <VBox spacing="12.0" style="-fx-border-color: rgba(255,255,255,0.30); -fx-border-width: 1 0 0 0; -fx-padding: 22 0 0 0;">
               <children>
                  <Label text="- Quick test requests and secure payments" textFill="#f8fafc" wrapText="true" />
                  <Label text="- Real-time sample tracking" textFill="#f8fafc" wrapText="true" />
                  <Label text="- Result vault with instant downloads" textFill="#f8fafc" wrapText="true" />
                  <Label text="- Email updates when reports are ready" textFill="#f8fafc" wrapText="true" />
               </children>
               <VBox.margin>
                  <Insets top="28.0" />
               </VBox.margin>
            </VBox>
         </children>
         <padding>
            <Insets bottom="44.0" left="44.0" right="38.0" top="44.0" />
         </padding>
      </VBox>

      <VBox alignment="CENTER" prefHeight="640.0" prefWidth="530.0" spacing="18.0" styleClass="auth-form-panel" HBox.hgrow="ALWAYS">
         <children>
            <VBox maxWidth="360.0" spacing="20.0" styleClass="card">
               <children>
                  <VBox spacing="6.0">
                     <children>
                        <Label styleClass="text-title" text="Create Account" />
                        <Label styleClass="text-subtitle" text="Register as a customer and verify your email." />
                     </children>
                  </VBox>

                  <VBox spacing="12.0">
                     <children>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Full Name" />
                              <TextField fx:id="nameField" promptText="Jane Doe" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Email Address" />
                              <TextField fx:id="emailField" promptText="jane@example.com" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Password" />
                              <PasswordField fx:id="passwordField" promptText="At least 6 characters" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Confirm Password" />
                              <PasswordField fx:id="confirmPasswordField" promptText="Repeat password" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <Label fx:id="errorLabel" textFill="#dc2626" wrapText="true" visible="false" />
                  <Button fx:id="registerButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleRegister" text="Create Account" />

                  <HBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label styleClass="text-subtitle" text="Already registered?" />
                        <Hyperlink onAction="#handleGoToLogin" text="Sign in" />
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="28.0" left="30.0" right="30.0" top="28.0" />
               </padding>
            </VBox>
         </children>
         <padding>
            <Insets bottom="44.0" left="46.0" right="46.0" top="44.0" />
         </padding>
      </VBox>
   </children>
</HBox>
